generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReportCycleStatus {
  draft
  completed
}

enum ReportEntryStatus {
  not_started
  in_progress
  submitted
  needs_revision
  completed
}

model Team {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  displayOrder   Int
  isActive       Boolean       @default(true)
  writeTokenHash String        @unique
  entries        ReportEntry[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([isActive, displayOrder])
}

model ReportCycle {
  id             String            @id @default(uuid()) @db.Uuid
  title          String
  startDate      DateTime          @db.Date
  endDate        DateTime          @db.Date
  dueDate        DateTime          @db.Date
  status         ReportCycleStatus @default(draft)
  shareTokenHash String            @unique
  entries        ReportEntry[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status, dueDate])
  @@index([startDate, endDate])
}

model ReportEntry {
  id            String            @id @default(uuid()) @db.Uuid
  reportCycleId String            @db.Uuid
  teamId        String            @db.Uuid
  status        ReportEntryStatus @default(not_started)
  submittedAt   DateTime?
  authorName    String?
  lastEditedBy  String?
  cycle         ReportCycle       @relation(fields: [reportCycleId], references: [id], onDelete: Cascade)
  team          Team              @relation(fields: [teamId], references: [id], onDelete: Restrict)
  workItems     WorkItem[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([reportCycleId, teamId])
  @@index([teamId, status])
}

model WorkItem {
  id            String      @id @default(uuid()) @db.Uuid
  reportEntryId String      @db.Uuid
  title         String
  description   String
  nextPlan      String
  note          String?
  displayOrder  Int
  entry         ReportEntry @relation(fields: [reportEntryId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([reportEntryId, displayOrder])
}

model AdminUser {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique
  passwordHash String
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Session {
  id          String    @id @default(uuid()) @db.Uuid
  adminUserId String    @db.Uuid
  tokenHash   String    @unique
  expiresAt   DateTime
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([adminUserId])
  @@index([expiresAt])
}
